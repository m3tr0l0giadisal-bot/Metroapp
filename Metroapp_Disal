  --disal-navy-light: #2a3894;
  --disal-green:      #2d7a4f;
  --disal-green-dark: #1e5436;
  --disal-teal:       #1a4a3e;
  --disal-surface:    #0d1530;
  --disal-surface2:   #0a1228;
  --disal-border:     rgba(30, 42, 120, 0.35);
  --disal-border2:    rgba(30, 42, 120, 0.18);
}

/* ── Body & global ── */
body {
  background: #06091a !important;
}

/* ── Borders: replace generic white/alpha → navy tinted ── */
.border-white\/\[0\.06\]  { border-color: var(--disal-border2) !important; }
.border-white\/\[0\.07\]  { border-color: var(--disal-border2) !important; }
.border-white\/\[0\.08\]  { border-color: rgba(30,42,120,0.22) !important; }
.border-white\/\[0\.1\]   { border-color: rgba(30,42,120,0.30) !important; }
.border-white\/\[0\.12\]  { border-color: rgba(30,42,120,0.40) !important; }

/* ── TOP HEADER — Disal navy gradient ── */
header {
  background: linear-gradient(135deg, #1e2a78 0%, #141d54 100%) !important;
  border-bottom: 1px solid rgba(255,255,255,0.10) !important;
}

/* ── SIDEBAR desktop ── */
aside {
  background: linear-gradient(180deg, #0d1530 0%, #0a1025 100%) !important;
  border-right: 1px solid rgba(30,42,120,0.30) !important;
}

/* ── MOBILE BOTTOM NAV ── */
nav.fixed.bottom-0 {
  background: linear-gradient(180deg, #0c1428ee 0%, #0a1025f5 100%) !important;
  border-top: 1px solid rgba(30,42,120,0.40) !important;
}

/* ── MOBILE DRAWER ── */
.bg-\[\#0d0f14\] {
  background: #0d1530 !important;
}

/* ── Logo "M" badge → Disal colors ── */
.from-\[\#3b82f6\].to-\[\#6366f1\] {
  background: linear-gradient(135deg, #1e2a78, #2d7a4f) !important;
}

/* ── Active nav item ── */
.bg-\[\#3b82f6\]\/12 {
  background-color: rgba(30, 42, 120, 0.20) !important;
}
.text-\[\#3b82f6\] {
  color: #6b8df5 !important;
}
.border-\[\#3b82f6\]\/20 {
  border-color: rgba(30, 42, 120, 0.35) !important;
}

/* ── Blue accents → Disal blue ── */
.bg-blue-500\/15 { background-color: rgba(30,42,120,0.22) !important; }
.bg-blue-500\/12 { background-color: rgba(30,42,120,0.18) !important; }
.bg-blue-500\/10 { background-color: rgba(30,42,120,0.15) !important; }
.bg-blue-500\/8  { background-color: rgba(30,42,120,0.12) !important; }
.border-blue-500\/25 { border-color: rgba(30,42,120,0.40) !important; }
.border-blue-500\/20 { border-color: rgba(30,42,120,0.32) !important; }
.text-blue-400 { color: #7b9ef8 !important; }
.text-blue-400\/70 { color: rgba(123,158,248,0.70) !important; }
.text-blue-400\/60 { color: rgba(123,158,248,0.60) !important; }
.text-blue-400\/50 { color: rgba(123,158,248,0.50) !important; }

/* ── Emerald/Green → Disal green (fits perfectly!) ── */
.text-emerald-400 { color: #4ade80 !important; }
.bg-emerald-500\/10 { background-color: rgba(45,122,79,0.15) !important; }
.border-emerald-500\/20 { border-color: rgba(45,122,79,0.30) !important; }
.bg-gradient-to-r.from-emerald-500 { background: linear-gradient(to right, #2d7a4f, #1e5436) !important; }
.from-emerald-500 { --tw-gradient-from: #2d7a4f !important; }
.to-emerald-500   { --tw-gradient-to:   #1e5436 !important; }
.to-teal-500      { --tw-gradient-to:   #1a4a3e !important; }

/* ── Metric card top stripes ── */
.bg-gradient-to-r.from-blue-500.to-indigo-500 {
  background: linear-gradient(to right, #1e2a78, #2a3894) !important;
}
.from-blue-500 { --tw-gradient-from: #1e2a78 !important; }
.to-indigo-500 { --tw-gradient-to:   #2a3894 !important; }

/* ── Sede PVM/PSL badges ── */
.bg-blue-500\/12.text-blue-400.border.border-blue-500\/20 {
  background-color: rgba(30,42,120,0.20) !important;
  color: #93b4ff !important;
  border-color: rgba(30,42,120,0.35) !important;
}

/* ── Focus rings → navy ── */
.focus\:border-blue-500\/40:focus { border-color: rgba(30,42,120,0.60) !important; }
.focus\:border-blue-500\/30:focus { border-color: rgba(30,42,120,0.45) !important; }

/* ── Search / input backgrounds ── */
.bg-white\/\[0\.04\] { background-color: rgba(30,42,120,0.10) !important; }
.bg-white\/\[0\.03\] { background-color: rgba(30,42,120,0.07) !important; }
.bg-white\/\[0\.02\] { background-color: rgba(30,42,120,0.05) !important; }
.bg-white\/\[0\.05\] { background-color: rgba(30,42,120,0.12) !important; }
.bg-white\/\[0\.06\] { background-color: rgba(30,42,120,0.14) !important; }
.bg-white\/\[0\.07\] { background-color: rgba(30,42,120,0.16) !important; }
.bg-white\/\[0\.08\] { background-color: rgba(30,42,120,0.18) !important; }

/* ── Avatar DR → Disal navy ── */
.from-\[\#6366f1\].to-\[\#a855f7\] {
  background: linear-gradient(135deg, #1e2a78, #2d7a4f) !important;
}

/* ── Modales ── */
.rounded-2xl.shadow-2xl {
  border-color: rgba(30,42,120,0.35) !important;
}

/* ── Loading spinner ── */
.border-t-\[\#3b82f6\] { border-top-color: #7b9ef8 !important; }

/* ── KPI bar progress ── */
.from-teal-500.to-emerald-500 {
  background: linear-gradient(to right, #1a4a3e, #2d7a4f) !important;
}

/* ─────────────────────────────────────────────
   HEADER CONTENT — texto e iconos sobre navy
   ───────────────────────────────────────────── */
header .text-white\/85 { color: rgba(255,255,255,0.92) !important; }
header .text-white\/25 { color: rgba(255,255,255,0.55) !important; }

/* Botón Alertas en header sobre fondo navy */
header .bg-white\/\[0\.03\] {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.15) !important;
}
header .text-white\/30 { color: rgba(255,255,255,0.65) !important; }
header .bg-white\/\[0\.05\] {
  background-color: rgba(255,255,255,0.10) !important;
}
header .border-white\/\[0\.05\] {
  border-color: rgba(255,255,255,0.15) !important;
}
header .text-white\/20 { color: rgba(255,255,255,0.55) !important; }

/* Logo M en header */
header .text-white\/40 { color: rgba(255,255,255,0.70) !important; }

/* ── Scrollbar navy-tinted ── */
::-webkit-scrollbar-thumb {
  background: rgba(30,42,120,0.40) !important;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(30,42,120,0.60) !important;
}
